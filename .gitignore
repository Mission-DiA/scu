**/image_prompts/**/images/*.jpg
**/image_prompts/**/images/*.jpeg
**/image_prompts/**/images/*.gif
**/image_prompts/**/images/*.webp
# Keep README files in images directories
!**/image_prompts/**/images/README.md

# Extended cut images and generated PDFs
**/extended-cut/images/
*.pdf

# OS files
.DS_Store
**/.DS_Store

# Editor files
*.swp
*.swo
*~
